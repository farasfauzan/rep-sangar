# ==============================================================================
# Laravel ERP Konstruksi - Production Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in ALL values marked with CHANGE_ME
# NEVER commit the actual .env file to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------
APP_NAME="ERP Konstruksi"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://erp.yourdomain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single,daily,slack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

LOG_DAILY_DAYS=30
LOG_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION (MySQL 8.0+)
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_konstruksi_production
DB_USERNAME=erp_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

DB_QUEUE_CONNECTION=mysql
DB_QUEUE_TABLE=jobs

# MySQL SSL (enable for production)
DB_SSL_MODE=REQUIRED
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem

# Connection pooling (via Laravel Octane or PgBouncer if needed)
# DB_POOL_SIZE=20

# ------------------------------------------------------------------------------
# SESSION CONFIGURATION
# ------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ------------------------------------------------------------------------------
# CACHE CONFIGURATION
# ------------------------------------------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=erp_prod_

# ------------------------------------------------------------------------------
# REDIS CONFIGURATION
# ------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_DB=0

REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90

# Redis Sentinel (for HA)
# REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_SENTINEL_SERVICE=mymaster

# ------------------------------------------------------------------------------
# QUEUE CONFIGURATION
# ------------------------------------------------------------------------------
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

# Horizon (if using Laravel Horizon)
# HORIZON_PREFIX=erp-prod
# HORIZON_USE_MAIN_DB=false

# ------------------------------------------------------------------------------
# MAIL CONFIGURATION (SMTP)
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# Alternative: Mailgun / Postmark / SES / Resend
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_SECRET=key-xxxxx
# MAILGUN_ENDPOINT=api.mailgun.net

# MAIL_MAILER=postmark
# POSTMARK_API_KEY=CHANGE_ME

# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_DEFAULT_REGION=us-east-1

# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxxxx

# ------------------------------------------------------------------------------
# FILESYSTEM / STORAGE CONFIGURATION
# ------------------------------------------------------------------------------
FILESYSTEM_DISK=local

# AWS S3 (for production file storage)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=erp-konstruksi-production
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=https://erp-konstruksi-production.s3.ap-southeast-1.amazonaws.com
AWS_ENDPOINT=
AWS_VISIBILITY=private

# DigitalOcean Spaces / Wasabi / MinIO (S3-compatible)
# AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
# AWS_URL=https://your-bucket.sgp1.digitaloceanspaces.com

# ------------------------------------------------------------------------------
# BROADCASTING / REALTIME (Laravel Reverb / Pusher / Soketi)
# ------------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=CHANGE_ME_APP_ID
REVERB_APP_KEY=CHANGE_ME_APP_KEY
REVERB_APP_SECRET=CHANGE_ME_APP_SECRET
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

# Pusher (alternative)
# PUSHER_APP_ID=CHANGE_ME
# PUSHER_APP_KEY=CHANGE_ME
# PUSHER_APP_SECRET=CHANGE_ME
# PUSHER_HOST=api.pusherapp.com
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=ap1

# ------------------------------------------------------------------------------
# APPLICATION KEYS (GENERATE WITH: php artisan key:generate --show)
# ------------------------------------------------------------------------------
APP_KEY=CHANGE_ME_BASE64_ENCODED_32_CHAR_KEY

# JWT Secret (if using tymon/jwt-auth)
# JWT_SECRET=CHANGE_ME_JWT_SECRET
# JWT_TTL=120
# JWT_REFRESH_TTL=20160

# ------------------------------------------------------------------------------
# SANCTUM / API TOKEN CONFIGURATION
# ------------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=erp.yourdomain.com,www.yourdomain.com
SESSION_DOMAIN=.yourdomain.com

# ------------------------------------------------------------------------------
# ERP-SPECIFIC CONFIGURATION
# ------------------------------------------------------------------------------

# Tax & Currency
TAX_RATE=0.11
DEFAULT_CURRENCY=IDR

# File Upload Limits
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,csv,jpg,jpeg,png,webp

# RAB Import Settings
RAB_IMPORT_MAX_ROWS=50000
RAB_IMPORT_CHUNK_SIZE=500
RAB_IMPORT_TIMEOUT=3600

# AI Classification Settings
AI_CLASSIFIER_ENABLED=true
AI_CLASSIFIER_MODEL=gpt-4o-mini
AI_CLASSIFIER_API_KEY=CHANGE_ME_OPENAI_KEY
AI_CLASSIFIER_BATCH_SIZE=50
AI_CLASSIFIER_CONFIDENCE_THRESHOLD=0.85

# PDF Generation (dompdf)
DOMPDF_ENABLE_REMOTE=true
DOMPDF_DEFAULT_FONT=DejaVu Sans

# ------------------------------------------------------------------------------
# EXTERNAL API INTEGRATIONS
# ------------------------------------------------------------------------------

# E-Faktur / DJP (Indonesia Tax)
EFaktur_API_URL=https://efaktur.pajak.go.id/api
EFaktur_CLIENT_ID=CHANGE_ME
EFaktur_CLIENT_SECRET=CHANGE_ME

# Midtrans / Payment Gateway
MIDTRANS_SERVER_KEY=CHANGE_ME
MIDTRANS_CLIENT_KEY=CHANGE_ME
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# Xendit (Alternative Payment)
# XENDIT_API_KEY=CHANGE_ME
# XENDIT_CALLBACK_TOKEN=CHANGE_ME

# WhatsApp Business API (for notifications)
WHATSAPP_API_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_BUSINESS_ACCOUNT_ID=CHANGE_ME

# Google Maps / Geocoding
GOOGLE_MAPS_API_KEY=CHANGE_ME

# ------------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# ------------------------------------------------------------------------------

# Sentry (Error Tracking)
SENTRY_LARAVEL_DSN=https://CHANGE_ME@sentry.io/PROJECT_ID
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=erp-konstruksi@1.0.0

# Laravel Telescope (disable in production)
TELESCOPE_ENABLED=false

# New Relic / DataDog / Other APM
# NEW_RELIC_APP_NAME="ERP Konstruksi Production"
# NEW_RELIC_LICENSE_KEY=CHANGE_ME

# ------------------------------------------------------------------------------
# SCHEDULER / CRON SETTINGS
# ------------------------------------------------------------------------------
SCHEDULER_TZ=Asia/Jakarta

# ------------------------------------------------------------------------------
# SECURITY SETTINGS
# ------------------------------------------------------------------------------
# CSRF
SANCTUM_CSRF_COOKIE_DOMAIN=.yourdomain.com

# CORS (configure in config/cors.php for production)
# CORS_ALLOWED_ORIGINS=https://erp.yourdomain.com,https://www.yourdomain.com

# Rate Limiting
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100

# ------------------------------------------------------------------------------
# PERFORMANCE OPTIMIZATION
# ------------------------------------------------------------------------------
# OpCache (configure in php.ini)
# opcache.enable=1
# opcache.memory_consumption=256
# opcache.interned_strings_buffer=16
# opcache.max_accelerated_files=20000
# opcache.validate_timestamps=0
# opcache.save_comments=1
# opcache.jit=1255
# opcache.jit_buffer_size=128M

# JIT (PHP 8.1+)
# pcre.jit=1

# ------------------------------------------------------------------------------
# BACKUP CONFIGURATION
# ------------------------------------------------------------------------------
BACKUP_DISK=s3
BACKUP_S3_BUCKET=erp-konstruksi-backups
BACKUP_S3_REGION=ap-southeast-1
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY

# Database Backup
DB_BACKUP_HOST=127.0.0.1
DB_BACKUP_PORT=3306
DB_BACKUP_DATABASE=erp_konstruksi_production
DB_BACKUP_USERNAME=backup_user
DB_BACKUP_PASSWORD=CHANGE_ME_BACKUP_PASSWORD

# ------------------------------------------------------------------------------
# VITE / FRONTEND ASSET CONFIGURATION
# ------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
VITE_API_URL="${APP_URL}/api"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------
FEATURE_RAB_AI_IMPORT=true
FEATURE_EFAKTUR_INTEGRATION=true
FEATURE_WHATSAPP_NOTIFICATIONS=true
FEATURE_ADVANCED_REPORTING=true
FEATURE_MULTI_TENANT=false

# ------------------------------------------------------------------------------
# DEBUGGING (DISABLE IN PRODUCTION)
# ------------------------------------------------------------------------------
# DEBUGBAR_ENABLED=false
# CLOCKWORK_ENABLED=false
# TELESCOPE_ENABLED=false

# ==============================================================================
# REQUIRED ACTIONS BEFORE DEPLOYMENT:
# ==============================================================================
# 1. Generate APP_KEY: php artisan key:generate --show
# 2. Replace ALL CHANGE_ME values with actual secrets
# 3. Configure SSL certificates (Let's Encrypt or paid)
# 4. Set up database user with minimal required privileges
# 5. Configure Redis with password and persistence
# 6. Set up S3 bucket with proper CORS and lifecycle policies
# 7. Configure mail provider (SMTP/Mailgun/SES/Resend)
# 8. Set up monitoring (Sentry, New Relic, etc.)
# 9. Configure backup encryption key
# 10. Test all integrations in staging first
# ==============================================================================